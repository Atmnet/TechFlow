# 服务器配置
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techflow

# Redis 配置
REDIS_URL=redis://localhost:6379

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# 日志配置
LOG_LEVEL=debug

# WebContainer 配置
WEBCONTAINER_TIMEOUT=30000
