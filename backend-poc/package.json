{
  "name": "techflow-backend",
  "version": "0.1.0",
  "description": "TechFlow Backend - K8s YAML Validation with WebContainers",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "fastify start -w -l debug src/app.js",
    "start": "fastify start -p 3000 src/app.js",
    "test": "node --test",
    "test:coverage": "c8 --reporter=html npm test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "k8s",
    "yaml",
    "validation",
    "webcontainers"
  ],
  "author": "TechFlow Team",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/postgres": "^6.0.2",
    "@fastify/redis": "^7.0.1",
    "@fastify/sensible": "^5.6.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/under-pressure": "^8.3.1",
    "fastify": "^4.26.2",
    "fastify-cli": "^6.1.1",
    "pg": "^8.11.3",
    "redis": "^4.6.13",
    "js-yaml": "^4.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "c8": "^9.1.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
